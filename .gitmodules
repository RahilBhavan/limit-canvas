[submodule "packages/contracts/lib/openzeppelin-contracts"]
	path = packages/contracts/lib/openzeppelin-contracts
	url = https://github.com/OpenZeppelin/openzeppelin-contracts
[submodule "packages/contracts/lib/limit-order-protocol"]
	path = packages/contracts/lib/limit-order-protocol
	url = https://github.com/1inch/limit-order-protocol.git
[submodule "packages/contracts/lib/forge-std"]
	path = packages/contracts/lib/forge-std
	url = https://github.com/foundry-rs/forge-std.git
[submodule "packages/contracts/lib/solidity-utils"]
	path = packages/contracts/lib/solidity-utils
	url = https://github.com/1inch/solidity-utils.git
